---
layout: layouts/base.njk
eleventyComputed:
  attachments: {{ attachments }}
  tags: {{ tags | cleanTags }}
  author: "{{ author }}"
  source: "{{ source }}"
  title: "{{ title }}"
---
<section id="content" class="prose dark:prose-invert prose-stone text-white container mx-auto font-sans px-4 py-2 my-2">
  <a href="javascript:history.back()" class="fixed top-8 left-8 bg-gray-900 p-2 w-12 h-12 text-center rounded-full no-underline">
  &larr;
  </a>
  <article>
{%- for attachment in attachments %}
  <figure class="w-full cv-auto overflow-clip flex justify-center ">
  {%- if attachment.type.startsWith("image") %}
    <div>
      <img class="h-128 drop-shadow-[0_8px_8px_rgba(255,255,255,0.5)] w-max object-contain{{ " render-pixelated" if attachment.pixel }} rounded-sm" src="{{ attachment.url | postImagePath }}" alt="{{ attachment.altText }}"/>
      <figcaption class="italic text-center text-lg md:text-sm">{{ attachment.description }}</figcaption>
    </div>

  {%- elseif attachment.type.startsWith("video") %}
      <video
        aria-label="{{ attachment.altText }}"
        class="max-h-svh w-full object-contain{{ " render-pixelated" if attachment.pixel }}"
        playsinline="true"
        preload="auto"
        controls="true"
        loop="true"
        src="{{ attachment.url | postImagePath }}"
      >
      </video>
  {%- endif %}
  </figure>
{%- endfor %}
  <div>
    <h1 class="font-serif text-center justify-center">{{ title }}</h1>
    <div class="w-full font-serif flex justify-center">
    {%- if author %}
    <p>
    </p>
    {%- endif %}

    </div>
    <div class="md:px-8">
      <div>{{ content | safe }}</div>
    </div>
    <div class="text-sm my-4 uppercase">
      <a href="{{ page.url }}">
        <time class="inline dt-published" datetime="{{ date | toISOString }}">{{ date | formatDate }}</time></a>
      {{ " • " }}
      <share-btn data-url="{{ metadata.url }}{{ page.url }}">
        <button class="hidden text-cerulean-600 underline cursor-pointer uppercase" title="Share this post">Share</button>
        <a
          title="Share this post"
          href="https://shareopenly.org/share/?url={{ metadata.url }}{{ page.url }}"
        >Share</a>
      </share-btn>
      {%- set cleanedTags = tags | cleanTags %}
      {{ " • " if cleanedTags.length }}
      <ul class="inline list-none">
      {%- for tag in cleanedTags %}
        <li class="inline mr-1">
          <a
            class="uppercase p-category"
            href="/t/{{ tag | slugify }}"
            aria-label="Posts tagged #{{ tag }}"
          >#{{ tag }}</a>
        </li>
      {%- endfor %}
      </ul>
    </div>
  </div>
</article>
</section>
{%- if collections.posts %}
{%- set nextPost = collections.posts | getPreviousCollectionItem %}
{%- set previousPost = collections.posts | getNextCollectionItem %}
{%- if nextPost or previousPost %}
{%- from "helpers/macros.njk" import pagination %}
{{ pagination(previousPost.url, nextPost.url) }}
{%- endif %}
{%- endif %}
